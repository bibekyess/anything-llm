# Copy to agent/.env and fill in ONE of the blocks below.
# Any OpenAI-compatible endpoint works (OpenRouter, Ollama, LM Studio, vLLM, ...).

# ── OpenRouter (cloud, good for a quick check) ─────────────────────────────
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-or-v1-REPLACE_ME
# Pick any tool-calling-capable model from https://openrouter.ai/models :
OPENAI_MODEL=anthropic/claude-sonnet-4.5
CONTEXT_WINDOW=128000

# Optional: model pricing in $ per MILLION tokens, used for the cost display.
# For OpenRouter endpoints this is fetched automatically from their catalog;
# set these to override, or to price local/self-hosted endpoints.
# MODEL_COST_INPUT=3.00
# MODEL_COST_OUTPUT=15.00
# MODEL_COST_CACHE_READ=0.30
# MODEL_COST_CACHE_WRITE=3.75

# ── Ollama (local, later) ──────────────────────────────────────────────────
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# Use a model that supports tool calling, e.g.:
# OPENAI_MODEL=qwen2.5:14b
# CONTEXT_WINDOW=32768

# ── LM Studio (local) ──────────────────────────────────────────────────────
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio
# OPENAI_MODEL=your-loaded-model-id
# CONTEXT_WINDOW=32768
